/* 页面标题 */
.page-header {
  padding: 24rpx 0 32rpx;
  text-align: center;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3d2b1f;
}

/* 元信息卡片 */
.meta-card {
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.meta-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.meta-titles {
  flex: 1;
}

.meta-label {
  font-size: 20rpx;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: #8b7355;
  display: block;
  margin-bottom: 8rpx;
}

.script-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #3d2b1f;
}

.cover-thumb {
  width: 96rpx;
  height: 128rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.meta-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(209, 196, 178, 0.5);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stat-icon {
  width: 56rpx;
  height: 56rpx;
  background: rgba(209, 196, 178, 0.3);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.stat-info {
  flex: 1;
}

.stat-label {
  font-size: 20rpx;
  color: #8b7355;
  display: block;
}

.stat-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #3d2b1f;
}

.truncate {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 160rpx;
}

/* 场次列表 */
.scenes-section {
  margin-top: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.section-count {
  font-size: 22rpx;
  color: #8b7355;
}

.scenes-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.scene-card {
  padding: 28rpx;
  position: relative;
  overflow: hidden;
}

.scene-number {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 72rpx;
  font-weight: bold;
  font-style: italic;
  color: rgba(61, 43, 31, 0.08);
  line-height: 1;
}

.scene-content {
  position: relative;
  z-index: 1;
}

.scene-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #3d2b1f;
  display: block;
  margin-bottom: 12rpx;
}

.scene-setting {
  font-size: 22rpx;
  color: #8b7355;
  display: block;
  margin-bottom: 16rpx;
}

.scene-preview {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #d1c4b2;
}

.quote-mark {
  font-size: 36rpx;
  color: #d1c4b2;
  line-height: 1;
}

.preview-text {
  font-size: 24rpx;
  color: #8b7355;
  font-style: italic;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 保存按钮区域 */
.save-section {
  margin-top: 48rpx;
  padding: 0 32rpx 32rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #8b7355 0%, #6b5344 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #f5f0e6;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.save-icon {
  font-size: 36rpx;
}

/* 已保存提示 */
.saved-hint {
  margin-top: 48rpx;
  padding: 24rpx;
  text-align: center;
  color: #6b8e6b;
  font-size: 28rpx;
}

/* 筛选区域 */
.filter-section {
  margin: 24rpx 32rpx;
  padding: 24rpx;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #3d2b1f;
}

.filter-clear {
  font-size: 24rpx;
  color: #8b7355;
  text-decoration: underline;
}

.filter-group {
  margin-bottom: 16rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 24rpx;
  color: #8b7355;
  margin-bottom: 12rpx;
  display: block;
}

.filter-tags {
  white-space: nowrap;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  background: rgba(139, 115, 85, 0.1);
  border: 1rpx solid #d1c4b2;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #5a4a3a;
  transition: all 0.2s;
}

.filter-tag.active {
  background: #8b7355;
  color: #f5f0e6;
  border-color: #8b7355;
}

.filter-tag:active {
  opacity: 0.8;
}

/* 场次人物标签 */
.scene-characters {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.character-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(139, 115, 85, 0.15);
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #6b5344;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #8b7355;
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #a09080;
}
