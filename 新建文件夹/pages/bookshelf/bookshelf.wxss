.page-container { padding: 28rpx; }

/* 头部 */
.header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.header-title { font-size: 36rpx; font-weight: 700; color: #4B7BF5; }
.header-sub   { font-size: 24rpx; color: #8899bb; }

/* 空状态 */
.empty-state {
  margin-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-icon { font-size: 76rpx; margin-bottom: 18rpx; }
.empty-text { font-size: 30rpx; color: #8899bb; margin-bottom: 8rpx; }
.empty-hint { font-size: 24rpx; color: #bcc8dd; }

/* 网格 */
.book-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding-bottom: 30rpx;
}
.book-wrapper {
  width: 48%;
  position: relative;
  margin-bottom: 28rpx;
}
.book-card {
  width: 100%;
  min-height: 280rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #fff;
  position: relative;
  transition: transform 220ms ease;
  box-sizing: border-box;
}
.book-card.swiped { transform: translateX(-70rpx); }

/* 封面 */
.cover {
  width: 100%;
  height: 150rpx;
  border-radius: 14rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-char {
  font-size: 52rpx;
  font-weight: 700;
  color: rgba(75, 123, 245, 0.28);
}

/* 信息 */
.book-info { color: #1a2a4a; }
.book-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.book-meta { display: block; font-size: 22rpx; color: #8899bb; line-height: 30rpx; }
.book-tag  {
  display: inline-block;
  font-size: 20rpx;
  color: #4B7BF5;
  background: #eef3ff;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 6rpx;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 130rpx;
  height: 68rpx;
  background: #ff5a5a;
  color: #fff;
  border-radius: 18rpx;
  font-size: 26rpx;
}
