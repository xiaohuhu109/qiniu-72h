.page-container { padding: 28rpx; }

/* 空状态 */
.empty-state {
  margin-top: 200rpx; display: flex; flex-direction: column; align-items: center;
}
.empty-icon { font-size: 76rpx; margin-bottom: 18rpx; }
.empty-text { font-size: 30rpx; color: #8899bb; margin-bottom: 8rpx; }
.empty-hint { font-size: 24rpx; color: #bcc8dd; text-align: center; line-height: 36rpx; }

/* 顶部 */
.top-bar {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx;
}
.book-name {
  font-size: 28rpx; font-weight: 600; color: #4B7BF5;
  max-width: 50%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.nav-row { display: flex; align-items: center; gap: 6rpx; }
.nav-btn {
  width: 54rpx; height: 54rpx; padding: 0; border-radius: 14rpx;
  background: #eef3ff; color: #4B7BF5; font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
}
.nav-label {
  font-size: 26rpx; font-weight: 600; color: #1a2a4a;
  min-width: 110rpx; text-align: center;
}

/* YAML 编辑区 */
.yaml-area {
  width: 100%; min-height: 520rpx; border-radius: 18rpx;
  background: #f8faff; padding: 24rpx; color: #1a2a4a;
  font-size: 26rpx; line-height: 42rpx;
  font-family: 'SF Mono', 'Menlo', 'Consolas', monospace;
  box-sizing: border-box;
}
.yaml-area.error { border: 2rpx solid #ff5a5a; background: #fff5f5; }

/* 按钮行 */
.btn-row { display: flex; gap: 12rpx; margin-top: 18rpx; }
.act-btn { flex: 1; padding: 20rpx 0; border-radius: 18rpx; font-size: 26rpx; }

/* 消息 */
.msg-box { margin-top: 18rpx; padding: 20rpx; border-radius: 16rpx; font-size: 26rpx; text-align: center; }
.msg-error { background: #fff5f5; color: #d93026; }
.msg-ok    { background: #f0f7f4; color: #1a8a6a; }
