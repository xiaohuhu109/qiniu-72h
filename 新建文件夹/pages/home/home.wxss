.page-container { padding: 28rpx; }

/* 标题卡片 */
.title-card {
  margin-bottom: 28rpx;
  padding: 42rpx 32rpx;
  border-radius: 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #ffffff, #f6f9ff);
}
.title-icon { font-size: 52rpx; display: block; margin-bottom: 10rpx; }
.title-text  {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #4B7BF5;
  margin-bottom: 8rpx;
}
.title-sub {
  font-size: 24rpx;
  color: #8899bb;
  line-height: 36rpx;
}

/* 输入卡片 */
.input-card { padding: 26rpx; }

/* 文件名提示条 */
.file-badge {
  display: flex;
  align-items: center;
  padding: 14rpx 18rpx;
  margin-bottom: 14rpx;
  background: #eef3ff;
  border-radius: 14rpx;
  border: 1rpx solid #d6e2fc;
}
.file-icon { font-size: 28rpx; margin-right: 10rpx; }
.file-name {
  flex: 1;
  font-size: 26rpx;
  color: #4B7BF5;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.file-clear {
  font-size: 28rpx;
  color: #8899bb;
  padding: 4rpx 12rpx;
  font-weight: 700;
}

/* 文本输入区 — 固定高度 1/3 屏，内容可滚动 */
.text-area {
  width: 100%;
  height: 33vh;
  border-radius: 18rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 46rpx;
  background: #f8faff;
  color: #1a2a4a;
  box-sizing: border-box;
}

/* 操作行 */
.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}
.upload-btn {
  width: 44%;
  padding: 18rpx 0;
  border-radius: 20rpx;
  font-size: 26rpx;
}
.radio-group { display: flex; gap: 14rpx; }
.radio-item  { display: flex; align-items: center; font-size: 26rpx; color: #1a2a4a; }

/* 生成按钮 */
.generate-btn {
  margin-top: 28rpx;
  width: 100%;
  padding: 26rpx 0;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
}
